<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgendaSQLiteMAUI.MainPage"
             Title="Mi Agenda">

    <Grid
        RowDefinitions="*,Auto"
        RowSpacing="0">

        <VerticalStackLayout
            Grid.Row="0"
            Padding="15"
            Spacing="10"
            BackgroundColor="#ECF0F1">

            <Label
                Text="MI AGENDA DE CONTACTOS"
                FontSize="32"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#2C3E50" />

            <StackLayout
                Orientation="Horizontal"
                Spacing="8">
                <Entry
                    Text="{Binding TerminoBusqueda}"
                    Placeholder="Buscar por nombre o teléfono"
                    FontSize="14"
                    BackgroundColor="White"
                    TextColor="#2C3E50"
                    PlaceholderColor="#95A5A6" />
                <Button
                    Text="🔍"
                    FontSize="20"
                    Padding="5"
                    BackgroundColor="#3498DB"
                    TextColor="White"
                    WidthRequest="50"
                    Command="{Binding BuscarContactosCommand}" />
                <Button
                    Text="✕"
                    FontSize="18"
                    Padding="5"
                    BackgroundColor="#E74C3C"
                    TextColor="White"
                    WidthRequest="50"
                    Command="{Binding LimpiarBusquedaCommand}" />
            </StackLayout>

            <CollectionView
                ItemsSource="{Binding Contactos}"
                SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem
                                        Text="Editar"
                                        BackgroundColor="#F39C12"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditarContactoCommand}"
                                        CommandParameter="{Binding .}" />
                                    <SwipeItem
                                        Text="Eliminar"
                                        BackgroundColor="#E74C3C"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EliminarContactoCommand}"
                                        CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Border
                                Stroke="#BDC3C7"
                                StrokeThickness="1"
                                Padding="15"
                                Margin="0,5"
                                BackgroundColor="White">
                                <VerticalStackLayout
                                    Spacing="5">
                                    <Label
                                        Text="{Binding Nombre}"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        TextColor="#2C3E50" />
                                    <Label
                                        Text="{Binding Telefono, StringFormat='📱 {0}'}"
                                        FontSize="14"
                                        TextColor="#34495E" />
                                    <Label
                                        Text="{Binding Email, StringFormat='✉️ {0}'}"
                                        FontSize="12"
                                        TextColor="#7F8C8D" />
                                    <Label
                                        Text="{Binding Direccion, StringFormat='📍 {0}'}"
                                        FontSize="12"
                                        TextColor="#7F8C8D" />
                                </VerticalStackLayout>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

        <Button
            Grid.Row="1"
            Text="+ NUEVO CONTACTO"
            FontSize="18"
            FontAttributes="Bold"
            Padding="15"
            BackgroundColor="#27AE60"
            TextColor="White"
            CornerRadius="0"
            Command="{Binding AgregarContactoCommand}" />

    </Grid>

    <AbsoluteLayout>
        <StackLayout
            x:Name="FormularioStack"
            IsVisible="{Binding MostrarFormulario}"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"
            Padding="20"
            Spacing="15"
            VerticalOptions="Center"
            BackgroundColor="#000000AA">

            <Border
                StrokeThickness="0"
                Padding="20"
                BackgroundColor="White">
                <VerticalStackLayout
                    Spacing="15">

                    <Label
                        Text="NUEVO CONTACTO"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="#2C3E50"
                        HorizontalOptions="Center" />

                    <Entry
                        Placeholder="Nombre *"
                        Text="{Binding ContactoSeleccionado.Nombre}"
                        FontSize="14"
                        BackgroundColor="#ECF0F1"
                        TextColor="#2C3E50"
                        PlaceholderColor="#95A5A6" />

                    <Entry
                        Placeholder="Teléfono"
                        Text="{Binding ContactoSeleccionado.Telefono}"
                        Keyboard="Numeric"
                        FontSize="14"
                        BackgroundColor="#ECF0F1"
                        TextColor="#2C3E50"
                        PlaceholderColor="#95A5A6" />

                    <Entry
                        Placeholder="Email"
                        Text="{Binding ContactoSeleccionado.Email}"
                        Keyboard="Email"
                        FontSize="14"
                        BackgroundColor="#ECF0F1"
                        TextColor="#2C3E50"
                        PlaceholderColor="#95A5A6" />

                    <Entry
                        Placeholder="Dirección"
                        Text="{Binding ContactoSeleccionado.Direccion}"
                        FontSize="14"
                        BackgroundColor="#ECF0F1"
                        TextColor="#2C3E50"
                        PlaceholderColor="#95A5A6" />

                    <StackLayout
                        Orientation="Horizontal"
                        Spacing="10">
                        <Button
                            Text="Guardar"
                            FontSize="16"
                            Padding="15"
                            BackgroundColor="#27AE60"
                            TextColor="White"
                            CornerRadius="8"
                            Clicked="OnGuardarClicked" />
                        <Button
                            Text="Cancelar"
                            FontSize="16"
                            Padding="15"
                            BackgroundColor="#95A5A6"
                            TextColor="White"
                            CornerRadius="8"
                            Clicked="OnCancelarClicked" />
                    </StackLayout>

                </VerticalStackLayout>
            </Border>

        </StackLayout>
    </AbsoluteLayout>

</ContentPage>
