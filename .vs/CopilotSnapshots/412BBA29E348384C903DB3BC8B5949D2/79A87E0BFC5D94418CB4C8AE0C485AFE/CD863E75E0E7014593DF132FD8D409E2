<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiPrimeraAppMAUI.MainPage"
             Title="Mi Primera App">

    <VerticalStackLayout
        Padding="20"
        Spacing="20"
        VerticalOptions="Center">

        <Label
            Text="Bienvenido"
            FontSize="32"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            TextColor="#2C3E50" />

        <Entry
            x:Name="NombreEntry"
            Placeholder="Ingresa tu nombre"
            FontSize="16"
            BackgroundColor="#ECF0F1"
            TextColor="#2C3E50"
            PlaceholderColor="#95A5A6" />

        <Button
            x:Name="SaludarBtn"
            Text="Saludar"
            FontSize="18"
            Padding="15"
            BackgroundColor="#3498DB"
            TextColor="White"
            CornerRadius="8"
            Clicked="OnSaludarClicked" />

        <Label
            x:Name="ResultadoLabel"
            Text="Aquí aparecerá el saludo"
            FontSize="18"
            HorizontalOptions="Center"
            TextColor="#27AE60"
            FontAttributes="Bold" />

    </VerticalStackLayout>

</ContentPage>
