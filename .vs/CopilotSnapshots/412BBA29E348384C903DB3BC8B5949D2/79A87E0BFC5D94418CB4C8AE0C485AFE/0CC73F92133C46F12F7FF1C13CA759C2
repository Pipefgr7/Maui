<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniCalculadoraMAUI.MainPage"
             Title="Mini Calculadora">

    <VerticalStackLayout
        Padding="20"
        Spacing="15"
        VerticalOptions="Center">

        <Label
            Text="CALCULADORA"
            FontSize="36"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            TextColor="#2C3E50" />

        <StackLayout
            Spacing="10"
            Orientation="Horizontal">
            <Label
                Text="Número 1:"
                FontSize="16"
                VerticalOptions="Center"
                TextColor="#34495E"
                WidthRequest="100" />
            <Entry
                x:Name="Numero1Entry"
                Placeholder="0"
                FontSize="16"
                Keyboard="Numeric"
                BackgroundColor="#ECF0F1"
                TextColor="#2C3E50"
                PlaceholderColor="#95A5A6" />
        </StackLayout>

        <StackLayout
            Spacing="10"
            Orientation="Horizontal">
            <Label
                Text="Número 2:"
                FontSize="16"
                VerticalOptions="Center"
                TextColor="#34495E"
                WidthRequest="100" />
            <Entry
                x:Name="Numero2Entry"
                Placeholder="0"
                FontSize="16"
                Keyboard="Numeric"
                BackgroundColor="#ECF0F1"
                TextColor="#2C3E50"
                PlaceholderColor="#95A5A6" />
        </StackLayout>

        <StackLayout
            Spacing="10"
            Orientation="Horizontal">
            <Label
                Text="Operación:"
                FontSize="16"
                VerticalOptions="Center"
                TextColor="#34495E"
                WidthRequest="100" />
            <Picker
                x:Name="OperacionPicker"
                Title="Seleccionar"
                BackgroundColor="#ECF0F1"
                TextColor="#2C3E50">
                <x:String>Sumar (+)</x:String>
                <x:String>Restar (-)</x:String>
                <x:String>Multiplicar (*)</x:String>
                <x:String>Dividir (/)</x:String>
            </Picker>
        </StackLayout>

        <Button
            x:Name="CalcularBtn"
            Text="Calcular"
            FontSize="18"
            Padding="15"
            BackgroundColor="#3498DB"
            TextColor="White"
            CornerRadius="8"
            Clicked="OnCalcularClicked" />

        <Label
            x:Name="ResultadoLabel"
            Text="Resultado: "
            FontSize="20"
            HorizontalOptions="Center"
            TextColor="#27AE60"
            FontAttributes="Bold" />

        <Label
            x:Name="MensajeLabel"
            Text=""
            FontSize="14"
            HorizontalOptions="Center"
            TextColor="#E74C3C" />

    </VerticalStackLayout>

</ContentPage>
